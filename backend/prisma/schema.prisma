generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  GERENTE
  EJECUTIVO
  TECNICO
}

enum CompanyType {
  CLIENTE
  PROSPECTO
  PROVEEDOR
}

enum LeadSource {
  WEB
  WHATSAPP
  EMAIL
  TELEFONO
  REFERIDO
  LICITACION
  OTRO
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id String @id @default(cuid())

  nombre   String
  apellido String

  email    String @unique
  password String

  telefono String?
  cargo    String?
  avatar   String?

  color String @default("#2563EB")

  role UserRole @default(EJECUTIVO)

  activo Boolean @default(true)

  ultimoLogin DateTime?

  companies Company[] @relation("CompanyExecutive")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

//////////////////////////////////////////////////////
// COMPANY
//////////////////////////////////////////////////////

model Company {
  id String @id @default(cuid())

  razonSocial String

  nombreFantasia String?

  rut String @unique

  giro String?

  direccion String?
  comuna    String?
  region    String?

  telefono String?
  email    String?
  sitioWeb String?

  tipo CompanyType @default(PROSPECTO)

  origen LeadSource?

  observaciones String?

  activo Boolean @default(true)

  ejecutivoId String?

  ejecutivo User? @relation("CompanyExecutive", fields: [ejecutivoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rut])
  @@index([ejecutivoId])
}
