generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  GERENTE
  EJECUTIVO
  TECNICO
  ASEO
  SUPERVISOR_ASEO
}

enum CompanyType {
  CLIENTE
  PROSPECTO
  PROVEEDOR
}

enum LeadSource {
  WEB
  WHATSAPP
  EMAIL
  TELEFONO
  REFERIDO
  LICITACION
  OTRO
}

enum ProspectStatus {
  NUEVO
  CONTACTADO
  VISITA_AGENDADA
  LEVANTAMIENTO
  COTIZANDO
  NEGOCIACION
  GANADO
  PERDIDO
}

enum ActivityType {
  LLAMADA
  EMAIL
  WHATSAPP
  REUNION
  VISITA
  TAREA
  NOTA
  COTIZACION
  OTRO
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id String @id @default(cuid())

  nombre   String
  apellido String

  email    String @unique
  password String

  telefono String?
  cargo    String?
  avatar   String?

  color String @default("#2563EB")

  role UserRole @default(EJECUTIVO)

  activo Boolean @default(true)

  ultimoLogin DateTime?

  companies Company[]  @relation("CompanyExecutive")
  prospects Prospect[] @relation("ProspectExecutive")
  

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  Activity  Activity[]

  @@index([email])
}

//////////////////////////////////////////////////////
// COMPANY
//////////////////////////////////////////////////////

model Company {
  id String @id @default(cuid())

  razonSocial String

  nombreFantasia String?

  rut String @unique

  giro String?

  direccion String?
  comuna    String?
  region    String?

  telefono String?
  email    String?
  sitioWeb String?

  tipo CompanyType @default(PROSPECTO)

  origen LeadSource?

  observaciones String?

  activo Boolean @default(true)

  ejecutivoId String?

  ejecutivo User? @relation("CompanyExecutive", fields: [ejecutivoId], references: [id])

  prospects Prospect[]

  activities Activity[]

  contacts Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rut])
  @@index([ejecutivoId])
}

model Prospect {
  id String @id @default(cuid())

  titulo String

  descripcion String?

  servicio String

  status ProspectStatus @default(NUEVO)

  valorEstimado Decimal? @db.Decimal(12, 2)

  fechaContacto DateTime?

  proximaAccion DateTime?

  companyId String?

  company Company? @relation(fields: [companyId], references: [id])

  ejecutivoId String?

  ejecutivo User? @relation("ProspectExecutive", fields: [ejecutivoId], references: [id])

  activities Activity[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  priority Priority @default(MEDIA)

  probabilidad Int @default(10)

  valorFinal Decimal? @db.Decimal(12, 2)

  fechaCierre DateTime?

  fechaPerdida DateTime?

  motivoPerdida String?

  @@index([status])
  @@index([companyId])
  @@index([ejecutivoId])
}

model Contact {
  id String @id @default(cuid())

  nombre String
  apellido String

  cargo String?

  telefono String?
  whatsapp String?

  email String?

  observaciones String?

  activo Boolean @default(true)

  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Activity {
  id String @id @default(cuid())

  titulo String
  descripcion String?

  tipo ActivityType

  realizada Boolean @default(false)

  fecha DateTime @default(now())

  // Ahora es opcional
  prospectId String?
  prospect Prospect? @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  // Usuario que realizó o creó la actividad
  userId String
  user User @relation(fields: [userId], references: [id])

  // Empresa asociada
  companyId String?
  company Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([companyId])
  @@index([userId])
  @@index([fecha])
}