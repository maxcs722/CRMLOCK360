generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GERENTE
  EJECUTIVO
  TECNICO
}

model User {
  id String @id @default(cuid())

  nombre   String
  apellido String

  email    String @unique
  password String

  telefono String?
  cargo    String?
  avatar   String?
  color    String  @default("#2563EB")

  role   UserRole @default(EJECUTIVO)
  activo Boolean  @default(true)

  ultimoLogin DateTime?

  companies Company[] @relation("CompanyExecutive")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id String @id @default(cuid())

  razonSocial    String
  nombreFantasia String?
  rut            String  @unique
  giro           String?

  direccion String?
  region    String?
  comuna    String?

  telefono String?
  email    String?
  sitioWeb String?

  ejecutivoId String?
  ejecutivo   User?   @relation("CompanyExecutive", fields: [ejecutivoId], references: [id])

  activo        Boolean @default(true)
  observaciones String?

  rubro       String?
  tipoCliente String?
  origen      String?

  contacts Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rut])
  @@index([ejecutivoId])
}

model Contact {
  id String @id @default(cuid())

  nombre   String
  apellido String?
  cargo    String?

  email    String?
  telefono String?
  celular  String?
  whatsapp String?

  principal          Boolean @default(false)
  recibeCotizaciones Boolean @default(true)
  recibeFacturas     Boolean @default(false)

  observaciones String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}
